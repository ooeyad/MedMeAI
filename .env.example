# --- Flask -----------------------------------------------------------------
FLASK_ENV=development
SECRET_KEY=change-me-secret-key
JWT_SECRET_KEY=change-me-jwt-key
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=14
LOG_LEVEL=INFO

# --- Database / cache ------------------------------------------------------
DATABASE_URL=postgresql+psycopg://medme:medme@postgres:5432/medme
REDIS_URL=redis://redis:6379/0

# --- Web origins (CORS) ----------------------------------------------------
WEB_ORIGINS=http://localhost:5173,http://localhost:3000

# --- File storage ----------------------------------------------------------
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# --- LLM provider (AI agent) ----------------------------------------------
# openai | anthropic | local
LLM_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- OCR -------------------------------------------------------------------
# tesseract | paddle | vision_llm
OCR_PROVIDER=tesseract

# --- Notification providers (all optional in dev) -------------------------
EMAIL_BACKEND=console
EMAIL_FROM=no-reply@medme.ai
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

SMS_BACKEND=console
SMS_FROM=MedMe

PUSH_BACKEND=console
WHATSAPP_BACKEND=console

# --- Celery ---------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Seed -----------------------------------------------------------------
SEED_DEFAULT_PASSWORD=ChangeMe!123
